# Application Settings
NODE_ENV=development          # Tells app it's in dev mode
PORT=3000                     # Your app runs on port 3000
API_PREFIX=api/v1            # API routes start with /api/v1

# Database - IMPORTANT: Use "mysql" as host (Docker service name)
DB_HOST=mysql                # Docker container name (NOT localhost!)
DB_PORT=3306                 # MySQL default port
DB_USERNAME=cms_user         # Can keep as-is for dev
DB_PASSWORD=cms_password_dev_123  # Can keep as-is for dev
DB_DATABASE=programming_club_cms  # Database name

# JWT Tokens - OK for dev, MUST CHANGE for production
JWT_SECRET=dev-secret-key-change-in-production
JWT_EXPIRATION=7d            # Token valid for 7 days
JWT_REFRESH_SECRET=dev-refresh-secret-change-in-production
JWT_REFRESH_EXPIRATION=30d   # Refresh token valid for 30 days

# File Upload Settings
UPLOAD_DIR=./uploads         # Where files are stored
MAX_FILE_SIZE=10485760       # 10MB max (in bytes)
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,application/pdf,text/plain

# Security - Rate limiting
THROTTLE_TTL=60              # Time window (60 seconds)
THROTTLE_LIMIT=10            # Max 10 requests per 60 seconds

# CORS - Which domains can access your API
CORS_ORIGIN=http://localhost:3000,http://localhost:3001