# ─── Application ─────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# ─── Database ─────────────────────────────────────────────────────────────────
# DB_HOST must be "mysql" (Docker service name) when running inside Docker,
# or "localhost" when connecting directly from your machine.
DB_HOST=mysql
DB_PORT=3306
DB_USERNAME=cms_user
DB_PASSWORD=cms_password_dev
DB_DATABASE=programming_club_cms

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Both secrets must be at least 32 characters.
JWT_SECRET=change-me-at-least-32-chars-xxxxxxxxxx
JWT_EXPIRATION=7d
JWT_REFRESH_SECRET=change-me-at-least-32-chars-xxxxxxxxxx
JWT_REFRESH_EXPIRATION=30d

# ─── File Upload ──────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,application/pdf,text/plain

# ─── Rate Limiting ────────────────────────────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=10

# ─── Email / SMTP ─────────────────────────────────────────────────────────────
MAIL_FROM=no-reply@bpc.local
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_SECURE=false
MAIL_USER=
MAIL_PASSWORD=
